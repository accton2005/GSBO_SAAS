{
  "entities": {
    "Organization": {
      "title": "Organization",
      "description": "A tenant organization (e.g., a municipality)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the organization" },
        "domain": { "type": "string", "description": "Subdomain for the organization" },
        "subscriptionPlanId": { "type": "string", "description": "ID of the subscription plan" },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": {
          "type": "object",
          "properties": {
            "appName": { "type": "string" },
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "logoUrl": { "type": "string" }
          }
        }
      },
      "required": ["name", "domain", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user within an organization",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "agent", "viewer"] },
        "serviceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "name", "email", "role", "createdAt"]
    },
    "Courrier": {
      "title": "Courrier",
      "description": "An administrative mail document",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "type": { "type": "string", "enum": ["entrant", "sortant"] },
        "reference": { "type": "string" },
        "objet": { "type": "string" },
        "expediteur": { "type": "string" },
        "destinataire": { "type": "string" },
        "dateReception": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["nouveau", "en_cours", "traite", "archive"] },
        "priority": { "type": "string", "enum": ["basse", "normale", "haute", "urgente"] },
        "documentUrl": { "type": "string" },
        "ocrText": { "type": "string" },
        "qrCodeData": { "type": "string" },
        "barcodeData": { "type": "string" },
        "serviceId": { "type": "string" },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "type", "reference", "objet", "status", "priority", "createdAt"]
    },
    "SMTPSettings": {
      "title": "SMTP Settings",
      "description": "SMTP configuration for an organization",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "number" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "encryption": { "type": "string", "enum": ["tls", "ssl", "none"] },
        "fromEmail": { "type": "string" },
        "fromName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      }
    },
    "APIToken": {
      "title": "API Token",
      "description": "REST API access tokens",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "token": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "revoked"] }
      }
    },
    "Webhook": {
      "title": "Webhook",
      "description": "Outgoing webhooks for events",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "eventType": { "type": "string" },
        "secret": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      }
    },
    "APILog": {
      "title": "API Log",
      "description": "History of API requests",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "tokenId": { "type": "string" },
        "endpoint": { "type": "string" },
        "method": { "type": "string" },
        "statusCode": { "type": "number" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "SaaSPlan": {
      "title": "SaaS Plan",
      "description": "Definition of a subscription plan",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "maxUsers": { "type": "number" },
        "maxStorageGB": { "type": "number" },
        "maxDocumentsPerMonth": { "type": "number" },
        "apiAccess": { "type": "boolean" },
        "workflowEnabled": { "type": "boolean" },
        "supportLevel": { "type": "string", "enum": ["standard", "priority", "dedicated"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "status", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Organization subscription instance",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "planId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["trial", "active", "expired", "suspended"] },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"] }
      },
      "required": ["organizationId", "planId", "startDate", "status"]
    },
    "SaaSActivityLog": {
      "title": "SaaS Activity Log",
      "description": "Super Admin activity logs",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Tenant organizations"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Platform users"
    },
    "/courriers/{courrierId}": {
      "schema": "Courrier",
      "description": "Mail documents"
    },
    "/smtp_settings/{id}": {
      "schema": "SMTPSettings",
      "description": "SMTP configurations"
    },
    "/api_tokens/{id}": {
      "schema": "APIToken",
      "description": "API access tokens"
    },
    "/webhooks/{id}": {
      "schema": "Webhook",
      "description": "Outgoing webhooks"
    },
    "/api_logs/{id}": {
      "schema": "APILog",
      "description": "API request logs"
    },
    "/saas_plans/{id}": {
      "schema": "SaaSPlan",
      "description": "SaaS subscription plans"
    },
    "/subscriptions/{id}": {
      "schema": "Subscription",
      "description": "Organization subscriptions"
    },
    "/saas_activity_logs/{id}": {
      "schema": "SaaSActivityLog",
      "description": "Super Admin logs"
    }
  }
}
